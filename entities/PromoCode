{
  "name": "PromoCode",
  "type": "object",
  "properties": {
    "code": {
      "type": "string",
      "description": "The promo code string e.g. NEON10"
    },
    "discount_type": {
      "type": "string",
      "enum": [
        "percentage",
        "fixed_amount"
      ],
      "default": "percentage"
    },
    "discount_value": {
      "type": "number",
      "description": "e.g. 10 for 10% or 5 for $5 off"
    },
    "scope": {
      "type": "string",
      "enum": [
        "global",
        "event"
      ],
      "default": "global",
      "description": "global or event-specific"
    },
    "event_id": {
      "type": "string",
      "description": "null = global, otherwise event-specific"
    },
    "usage_limit": {
      "type": "number",
      "default": 0,
      "description": "0 = unlimited"
    },
    "per_user_limit": {
      "type": "number",
      "default": 1,
      "description": "Max uses per user, 0 = unlimited"
    },
    "used_count": {
      "type": "number",
      "default": 0
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive",
        "expired"
      ],
      "default": "active"
    },
    "starts_at": {
      "type": "string",
      "description": "ISO timestamp when code becomes valid"
    },
    "expires_at": {
      "type": "string",
      "description": "ISO timestamp when code expires"
    },
    "created_by": {
      "type": "string",
      "description": "Admin user ID who created this code"
    },
    "description": {
      "type": "string"
    }
  },
  "required": [
    "code",
    "discount_type",
    "discount_value"
  ]
}
