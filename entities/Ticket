{
  "name": "Ticket",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string"
    },
    "user_name": {
      "type": "string"
    },
    "user_email": {
      "type": "string"
    },
    "event_id": {
      "type": "string"
    },
    "event_name": {
      "type": "string"
    },
    "event_start_time": {
      "type": "string",
      "description": "ISO timestamp of event start"
    },
    "ticket_type": {
      "type": "string",
      "default": "app_rsvp",
      "description": "app_rsvp, at_door, group_pass"
    },
    "ticket_barcode": {
      "type": "string",
      "description": "NV-TICKET-{id}"
    },
    "original_price": {
      "type": "number",
      "default": 10
    },
    "discount_amount": {
      "type": "number",
      "default": 0
    },
    "final_amount_paid": {
      "type": "number",
      "default": 0
    },
    "points_awarded": {
      "type": "number",
      "default": 0
    },
    "reward_applied_id": {
      "type": "string"
    },
    "reward_applied_name": {
      "type": "string"
    },
    "promo_code_used": {
      "type": "string"
    },
    "payment_id": {
      "type": "string"
    },
    "payment_status": {
      "type": "string",
      "enum": [
        "pending",
        "paid",
        "refunded",
        "free"
      ],
      "default": "pending"
    },
    "ticket_status": {
      "type": "string",
      "enum": [
        "active",
        "used",
        "refunded",
        "expired",
        "cancelled"
      ],
      "default": "active"
    },
    "payment_method": {
      "type": "string"
    },
    "provider_payment_id": {
      "type": "string"
    },
    "purchased_at": {
      "type": "string"
    },
    "used_at": {
      "type": "string"
    },
    "refunded_at": {
      "type": "string"
    },
    "refund_deadline": {
      "type": "string",
      "description": "ISO timestamp: 24h before event start"
    }
  },
  "required": [
    "user_email",
    "event_id",
    "event_name"
  ]
}
